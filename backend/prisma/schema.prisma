generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  password      String
  name          String?
  verified      Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  favoriteTeams FavoriteTeam[]
  refreshTokens RefreshToken[]
  preferences   UserPreference?
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FavoriteTeam {
  id       String @id @default(cuid())
  userId   String
  teamName String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeamReport {
  id        String   @id @default(cuid())
  teamName  String   @unique
  report    String
  news      Json?
  updatedAt DateTime @updatedAt
}

model UserPreference {
  id                           String   @id @default(cuid())
  userId                       String   @unique
  receiveDailyNotifications    Boolean  @default(true)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  user                         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FootballMatch {
  id                 String   @id @default(cuid())
  date               DateTime
  championship       String
  homeTeam           String
  awayTeam           String
  status             String
  externalId         String?  @unique
  homeScore          Int?
  awayScore          Int?
  awayFlag           String?
  homeFlag           String?
  predictedCards     Float?
  predictedFouls     Float?
  predictedGoalsAway Float?
  predictedGoalsHome Float?
  homeTactics        Json?
  awayTactics        Json?
  aiAnalysis         String?

  @@index([date])
  @@index([championship])
}

/**
 * Estado PERSISTIDO do bracket de mata-mata da Copa do Mundo.
 *
 * POR QUE ISSO EXISTE (não recalcule isso no frontend de novo):
 * Antes desta tabela, cada confronto do bracket era recalculado do zero a cada
 * render, a partir do histórico de jogos + tabela de grupos. Isso causava
 * "flicker" onde um confronto já definido mudava sozinho, ou sumia, porque
 * a ordenação de desempate ou o timing de sync de um jogo específico mudava
 * o resultado do cálculo entre uma atualização e outra.
 *
 * Regra de ouro: um BracketSlot, uma vez marcado como RESOLVED, nunca deve
 * ser recalculado a partir do zero. Ele só avança pra frente (RESOLVED →
 * IN_PROGRESS → DONE) conforme jogos reais terminam. Nunca "desresolva" um
 * slot que já tinha os dois times definidos.
 */
model BracketSlot {
  id          String   @id @default(cuid())
  /** Número oficial FIFA do jogo (73-88 = Rd32, 89-96 = Rd16, 97-100 = QF, 101-102 = Semi, 104 = Final) */
  gameNumber  Int      @unique
  phase       String   // 'r32' | 'r16' | 'quartas' | 'semi' | 'final'

  /** Slot ainda não resolvido: guarda a notação ("1A", "2B", "3ABCDF"). Resolvido: guarda o nome do time. */
  homeSlot    String
  awaySlot    String

  /** Preenchido só quando o slot correspondente já foi calculado uma vez — depois disso, imutável. */
  homeTeam    String?
  awayTeam    String?

  /** Vínculo com o jogo real no FootballMatch, uma vez que ele exista. */
  matchId     String?  @unique
  homeScore   Int?
  awayScore   Int?
  status      String   @default("PENDING") // PENDING | RESOLVED | IN_PROGRESS | DONE

  /** Time vencedor, preenchido quando status = DONE. Alimenta a fase seguinte. */
  winner      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([phase])
}
